Authorization: Bearer {{id_amico}}

> {% console.log("chats:"); if(response.body["chats"]){response.body["chats"].forEach(chat => { console.log("\n\tchatId <"+ chat.chatId +">:\n\t\tchatName -> "+ chat.chatName +"\n\t\tchatPhoto -> "+ (chat.chatPhoto).substring(0,10) +"...\n\t\tisGroup -> "+ chat.isGroup +"\n\t\tparticipants-> "+ chat.participants)}); client.global.set("fede_chatId", response.body["chats"][0]["chatId"]);}else{console.log("no chat")} %}


