### POST request for login
POST http://localhost:3000/session
Content-Type: application/json

{"userName": "fede"}

> {% client.global.set("client_token", response.headers.valueOf("Authorization").split(' ')[1]) ; client.global.set("usrId", response.body.valueOf()["usrId"] ); console.log(client.global.get("usrId")) %}


### GET request for listing all the users
GET http://localhost:3000/users
Authorization: Bearer {{client_token}}

> {% console.log(response.body); client.global.set("id_amico", response.body["users"][1]["usrId"]); console.log("id amico: ", client.global.get("id_amico")) %}


### GET request for listing the user info
GET http://localhost:3000/users/{{id_amico}}
Authorization: Bearer {{client_token}}

> {% console.log("nome: "+ response.body["userName"] +"\nfoto: "+ response.body["userPhoto"] +"\nid: "+ response.body["usrId"]) %}


### PATCH request for change user name
PATCH http://localhost:3000/users/{{id_amico}}
Authorization: Bearer {{id_amico}}
Content-Type: application/json-patch+json

{
  "newUserName": "armando"
}

### PATCH request for change user photo
PATCH localhost:3000/users/{{id_amico}}/propic
Authorization: Bearer {{id_amico}}
Content-Type: application/json-patch+json

{
  "newUserPhoto": ""
}

### GET request for retriving user's chats
GET localhost:3000/chats
Authorization: Bearer {{client_token}}

> {% console.log("chats: \n\t") %}
